{
  "expo": {
    "name": "Sustainable Supply Academy",
    "slug": "ieu-cepa-scan",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "ieu-cepa-scan",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a5276"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ieucepa.scan"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a5276"
      },
      "package": "com.ieucepa.scan",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
